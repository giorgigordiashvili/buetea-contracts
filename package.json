{
  "name": "buetea-contracts",
  "version": "0.5.0",
  "description": "Shared Zod request/response contracts for the Buetea API (server + web + mobile + courier).",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "zod": "^4"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.7.3",
    "zod": "4.1.11"
  }
}
